<Application x:Class="InterlinedList.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <!-- [0] Invariant brand palette — never swapped -->
                <ResourceDictionary Source="Resources/Palette.xaml"/>
                <!-- [1] Semantic theme — swapped at runtime in App.xaml.cs -->
                <ResourceDictionary Source="Resources/Theme.Light.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Application.Resources>
</Application>
