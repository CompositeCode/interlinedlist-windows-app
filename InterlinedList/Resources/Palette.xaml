<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!--
        InterlinedList — Strata brand palette
        Derived from brand-kit/theme/tokens.json  |  Do not edit manually.
        If tokens.json changes, update Color values here and in Theme.Light/Dark.xaml.
    -->

    <!-- ── Brand colors ──────────────────────────────────────────── -->
    <Color x:Key="Green">#FF2FA877</Color>
    <Color x:Key="GreenHover">#FF28936A</Color>
    <Color x:Key="GreenDark">#FF3FBF8C</Color>
    <Color x:Key="Teal">#FF184860</Color>
    <Color x:Key="TealDeep">#FF0C2C3A</Color>
    <Color x:Key="TealAccent">#FF7FB8C4</Color>
    <Color x:Key="TealBright">#FF4FD09C</Color>
    <Color x:Key="Amber">#FFF0A830</Color>
    <Color x:Key="AmberHover">#FFDB9720</Color>

    <!-- ── Invariant brushes ─────────────────────────────────────── -->
    <SolidColorBrush x:Key="GreenBrush"      Color="{StaticResource Green}"/>
    <SolidColorBrush x:Key="GreenHoverBrush" Color="{StaticResource GreenHover}"/>
    <SolidColorBrush x:Key="TealBrush"       Color="{StaticResource Teal}"/>
    <SolidColorBrush x:Key="TealDeepBrush"   Color="{StaticResource TealDeep}"/>
    <SolidColorBrush x:Key="TealAccentBrush" Color="{StaticResource TealAccent}"/>
    <SolidColorBrush x:Key="TealBrightBrush" Color="{StaticResource TealBright}"/>
    <SolidColorBrush x:Key="AmberBrush"      Color="{StaticResource Amber}"/>
    <SolidColorBrush x:Key="AmberHoverBrush" Color="{StaticResource AmberHover}"/>

    <!-- Titlebar always uses TealDeep regardless of light/dark -->
    <SolidColorBrush x:Key="TitlebarBrush"     Color="{StaticResource TealDeep}"/>
    <SolidColorBrush x:Key="TitlebarTextBrush" Color="White"/>

</ResourceDictionary>
