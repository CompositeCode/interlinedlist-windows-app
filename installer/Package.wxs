<?xml version="1.0" encoding="UTF-8"?>
<Wix xmlns="http://wixtoolset.org/schemas/v4/wxs"
     xmlns:ui="http://wixtoolset.org/schemas/v4/wxs/ui">

  <Package Name="InterlinedList"
           Manufacturer="InterlinedList"
           Version="1.0.0.0"
           UpgradeCode="F6E4FF67-5FBC-47BD-B506-D2A033685E0F"
           Language="1033"
           Compressed="yes"
           Scope="perMachine">

    <SummaryInformation Description="InterlinedList — signal streams, live." Manufacturer="InterlinedList" />

    <MajorUpgrade DowngradeErrorMessage="A newer version of [ProductName] is already installed." />
    <MediaTemplate EmbedCab="yes" />

    <Icon Id="InterlinedList.ico" SourceFile="..\brand-kit\icons\windows\InterlinedList.ico" />
    <Property Id="ARPPRODUCTICON" Value="InterlinedList.ico" />
    <!-- ARPNOMODIFY is already set by the WixUI_Minimal wixlib below; redeclaring it here collides. -->
    <Property Id="ARPURLINFOABOUT" Value="https://interlinedlist.com" />

    <StandardDirectory Id="ProgramFiles64Folder">
      <Directory Id="INSTALLFOLDER" Name="InterlinedList" />
    </StandardDirectory>

    <StandardDirectory Id="ProgramMenuFolder">
      <Directory Id="ApplicationProgramsFolder" Name="InterlinedList" />
    </StandardDirectory>

    <DirectoryRef Id="ApplicationProgramsFolder">
      <Component Id="ApplicationShortcut" Guid="1BF94658-594E-4F7F-998D-BFC7016BD96D">
        <Shortcut Id="AppStartMenuShortcut"
                  Name="InterlinedList"
                  Description="InterlinedList — signal streams, live."
                  Target="[INSTALLFOLDER]InterlinedList.exe"
                  WorkingDirectory="INSTALLFOLDER"
                  Icon="InterlinedList.ico" />
        <RemoveFolder Id="RemoveApplicationProgramsFolder" On="uninstall" />
        <RegistryValue Root="HKCU" Key="Software\InterlinedList" Name="installed" Type="integer" Value="1" KeyPath="yes" />
      </Component>
    </DirectoryRef>

    <ComponentGroup Id="AppFiles" Directory="INSTALLFOLDER">
      <Files Include="$(var.PublishDir)\**" />
    </ComponentGroup>

    <Feature Id="MainFeature" Title="InterlinedList" Level="1">
      <ComponentGroupRef Id="AppFiles" />
      <ComponentRef Id="ApplicationShortcut" />
    </Feature>

    <ui:WixUI Id="WixUI_Minimal" />
    <WixVariable Id="WixUILicenseRtf" Value="License.rtf" />

  </Package>
</Wix>
